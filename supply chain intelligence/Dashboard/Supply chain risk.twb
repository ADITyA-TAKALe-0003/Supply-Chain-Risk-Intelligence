      <aliases enabled='yes' />
      <column caption='Total_Lead_Time' datatype='integer' name='[Calculation_1318215051722752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Lead times] + [Shipping times] + [Manufacturing lead time]' />
      </column>
      <column caption='Total Cost' datatype='real' name='[Calculation_1318215053017089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Manufacturing costs] + [Shipping costs] + [Costs]' />
      </column>
      <column caption='Quality Flag' datatype='integer' name='[Calculation_1318215053131778]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Inspection results] = &quot;Fail&quot; THEN 1&#10;ELSE 0&#10;END' />
      </column>
      <column caption='Composite_Risk_Scoren1' datatype='real' name='[Calculation_1318215053279235]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Defect rates] * 0.4) +&#10;([Calculation_1318215051722752] * 0.3) +&#10;([Calculation_1318215053017089] * 0.3)' />
      </column>
      <column caption='Risk Category' datatype='string' name='[Calculation_1318215053398020]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1318215053279235] &gt; 170 THEN &quot;High Risk&quot;&#10;ELSEIF [Calculation_1318215053279235] &gt; 130 THEN &quot;Medium Risk&quot;&#10;ELSE &quot;Low Risk&quot;&#10;END' />
      </column>
      <column caption='Inventory Turnover' datatype='real' name='[Calculation_1420260943847424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Number of products sold] / [Stock levels]' />
      </column>
      <column caption='Stock Risk' datatype='string' name='[Calculation_1420260944121857]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Stock levels] &lt; 20 THEN &quot;Low Stock 🚨&quot;&#10;ELSEIF [Stock levels] &gt; 80 THEN &quot;Overstock ⚠️&quot;&#10;ELSE &quot;Healthy ✅&quot;&#10;END' />
      </column>
      <column caption='Fulfillment Gap' datatype='integer' name='[Calculation_1420260944232450]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Order quantities] - [Production volumes]' />
      </column>
      <column caption='Lead Time Risk' datatype='integer' name='[Calculation_1420260944318467]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Lead time] + [Shipping times]' />
      </column>
      <column caption='Revenue per Unit Sold' datatype='real' name='[Calculation_1420260944482308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Revenue generated] / [Number of products sold]' />
      </column>
      <column caption='Shipping Cost %' datatype='real' name='[Calculation_1420260944588805]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Shipping costs] / [Revenue generated]' />
      </column>
      <column caption='supply_chain_data.csv' datatype='table' name='[__tableau_internal_object_id__].[supply_chain_data.csv_BDFD683837A6403EAD51102FFDF92076]' role='measure' type='quantitative' />
